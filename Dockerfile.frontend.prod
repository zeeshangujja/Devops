# Base image 
FROM node:20.11.1

# Install http-server globally for serving the frontend
RUN npm install -g http-server
RUN npm install -g angular-http-server

# Set the working directory for frontend
WORKDIR /app/cli

# Copy the package.json and package-lock.json for the frontend
COPY cli/package*.json ./

# Install frontend dependencies
RUN npm install

# Copy the entire client folder to ensure the workspace is present
COPY cli/ .

# Build the frontend for staging
RUN npm run build-server

# Expose the frontend ports
EXPOSE ....

# Start http-server for the frontend
CMD ["sh", "-c", "angular-http-server --path /app/client/dist/client/browser -p .... --host ....."]
